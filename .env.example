# ============================================
# Triage Agent — Environment Variables
# ============================================

# OpenAI (required for the LLM)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# MCP Server URL (default: http://localhost:8000/mcp)
MCP_SERVER_URL=http://localhost:8000/mcp

# ============================================
# LangSmith (optional — for tracing & Studio)
# ============================================
# Get your key at: https://smith.langchain.com/settings
LANGSMITH_API_KEY=ls-...
LANGSMITH_PROJECT=how-agents-talk
LANGSMITH_TRACING=true

# Legacy env var names (also accepted by LangChain v1.2+)
# LANGCHAIN_API_KEY=ls-...
# LANGCHAIN_PROJECT=how-agents-talk
# LANGCHAIN_TRACING_V2=true

# ============================================
# MCP Server Adapters (optional — for real integrations)
# ============================================
METRICS_ADAPTER=mock
LOGS_ADAPTER=mock
NOTIFICATIONS_ADAPTER=mock

# Datadog (only needed if METRICS_ADAPTER=datadog)
# DD_API_KEY=...
# DD_APP_KEY=...

# PagerDuty (only needed if NOTIFICATIONS_ADAPTER=pagerduty)
# PD_API_KEY=...
# PD_SERVICE_ID=...
